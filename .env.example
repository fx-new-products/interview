# ベースURL（本番 nginx 経由では /interview/、ローカル単独なら / でもOK）
BASE_URL=/interview/

# Google Calendar API（OAuth2 リフレッシュトークン方式）
# ~/work/ai-degico/.env から GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET / GOOGLE_REFRESH_TOKEN
# の値をそのままコピーして使う（freedom.co.jp の共有トークン）
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=
NUXT_GOOGLE_REFRESH_TOKEN=

# 面談イベントを取得するカレンダーID（ローカル開発用フォールバック）
# 本番 (Unified Platform 経由) では oauth2-proxy の X-Email ヘッダを
# calendarId としてそのまま使うため、この値は参照されない。
# ローカル開発では X-Email が無いので、ここで明示したカレンダーを見る。
# refresh_token 所有者が対象カレンダーに閲覧権限を持つ前提（freedom.co.jp 内で共有済み）。
NUXT_CALENDAR_ID=
